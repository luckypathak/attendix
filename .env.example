# ==============================================================================
# Attendix Workforce OS - Environment Variables Example
# Copy this file to .env and fill in the values for your environment.
# ==============================================================================

# General Settings
DEBUG=True
SECRET_KEY=django-insecure-attendix-workforce-os-development-secret-key-change-me
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=attendix_db
DB_USER=attendix_user
DB_PASSWORD=attendix_password
DB_HOST=db
DB_PORT=5432

# Redis & Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Authentication (JWT Settings)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Media Storage (Cloudinary prototype)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Push Notifications (Firebase Cloud Messaging)
FCM_SERVER_KEY=your_fcm_server_key
FCM_CREDENTIALS_JSON_PATH=credentials/firebase_service_account.json

# SMS Gateway Settings
SMS_GATEWAY_API_KEY=attendix_gateway_secret_api_key_123

# Admin Configs
INITIAL_SUPERADMIN_EMAIL=admin@attendix.com
INITIAL_SUPERADMIN_PASSWORD=AdminPassword123!
